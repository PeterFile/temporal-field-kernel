# Embedded Datalog-like MVP rules. Syntax is documentation-only for now.
# The Rust API in tfk-rules builds these rules programmatically.

active(C) :- continuation(C), continuation_status(C, "active").
needs_review(C) :- active(C), risk_level(C, "high").
risk_marker(C, "review") :- needs_review(C).
